#!/usr/bin/env sh
# Neko Agent Manager for Android (Magisk)
# Format: .conf (Android Style)
set -eu

PROG="nekoagent"
AGENT_BIN="/system/bin/neko-agent"
BASE_DIR="/data/adb/neko-agent"
# 默认主配置文件
DEFAULT_CONF="$BASE_DIR/agent.conf"
STATE_DIR="$BASE_DIR/run"
VERSION="0.2.3-android"

log() { printf '[%s] %s\n' "$PROG" "$1"; }
err() { printf '[%s] error: %s\n' "$PROG" "$1" >&2; }

ensure_dirs() { mkdir -p "$BASE_DIR" "$STATE_DIR"; }

pid_file() { printf '%s/%s.pid\n' "$STATE_DIR" "$1"; }
log_file() { printf '%s/%s.log\n' "$STATE_DIR" "$1"; }

is_running() {
  pf="$(pid_file "$1")"
  [ ! -f "$pf" ] && return 1
  pid="$(cat "$pf" 2>/dev/null || true)"
  [ -z "$pid" ] && return 1
  kill -0 "$pid" >/dev/null 2>&1
}

# ── 核心解析逻辑 ────────────────────────────────────────────────────────────

load_config() {
  conf_path="$1"
  if [ ! -f "$conf_path" ]; then
    err "配置文件未找到: $conf_path"
    exit 1
  fi

  # 转换安卓风格的 key = value 为 Shell 变量
  # 1. 过滤注释行和空行
  # 2. 去掉等号前后的空格
  # 3. 统一加上 NEKO_ 前缀 (例如 server_url 变成 NEKO_SERVER_URL)
  # 4. 将 key 转换为大写以符合 Go 程序的变量习惯
  
  config_raw=$(grep -v '^#' "$conf_path" | grep '=')
  
  eval "$(echo "$config_raw" | sed 's/ *= */=/g' | awk -F= '{print "NEKO_" toupper($1) "=" $2}')"
}

build_agent_args() {
  # 此时变量已被 load_config 注入为 NEKO_SERVER_URL 等
  [ -z "${NEKO_SERVER_URL:-}" ] && { err "配置中缺少 server_url"; exit 1; }
  
  set -- \
    --server-url "$NEKO_SERVER_URL" \
    --backend-id "$NEKO_BACKEND_ID" \
    --backend-token "$NEKO_BACKEND_TOKEN" \
    --gateway-type "$NEKO_GATEWAY_TYPE" \
    --gateway-url "$NEKO_GATEWAY_URL"

  [ -n "${NEKO_GATEWAY_TOKEN:-}" ] && set -- "$@" --gateway-token "$NEKO_GATEWAY_TOKEN"
  [ -n "${NEKO_LOG:-}" ] && set -- "$@" --log="$NEKO_LOG"
  [ -n "${NEKO_AGENT_ID:-}" ] && set -- "$@" --agent-id "$NEKO_AGENT_ID"
  
  printf '%s\n' "$*"
}

# ── 命令处理 ────────────────────────────────────────────────────────────────

cmd_start() {
  name="${1:-agent}" # 默认为 agent
  conf_target="$BASE_DIR/${name}.conf"
  ensure_dirs

  if is_running "$name"; then
    log "实例 '$name' 正在运行中 (PID: $(cat "$(pid_file "$name")"))"
    return 0
  fi

  load_config "$conf_target"
  args="$(build_agent_args)"
  lf="$(log_file "$name")"
  pf="$(pid_file "$name")"

  nohup "$AGENT_BIN" $args >> "$lf" 2>&1 &
  pid=$!
  printf '%s\n' "$pid" > "$pf"
  log "实例 '$name' 已启动 (PID: $pid)"
}

cmd_stop() {
  name="${1:-agent}"
  pf="$(pid_file "$name")"
  if ! is_running "$name"; then
    [ -f "$pf" ] && rm -f "$pf"
    log "实例 '$name' 未运行"
    return 0
  fi
  pid="$(cat "$pf")"
  kill "$pid" >/dev/null 2>&1 || true
  sleep 1
  kill -9 "$pid" >/dev/null 2>&1 || true
  rm -f "$pf"
  log "实例 '$name' 已停止"
}

cmd_status() {
  name="${1:-agent}"
  if is_running "$name"; then
    log "实例 '$name' 状态: 运行中 (PID: $(cat "$(pid_file "$name")"))"
    exit 0
  fi
  log "实例 '$name' 状态: 已停止"
  exit 1
}

# ── 入口 ────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
Neko Agent 管理器 (安卓版)
基础路径: $BASE_DIR

用法:
  nekoagent start [name]    # 启动 (默认读取 agent.conf)
  nekoagent stop [name]     # 停止
  nekoagent status [name]   # 查看状态
  nekoagent logs [name]     # 查看日志
  nekoagent list            # 列出所有 .conf 配置
EOF
}

main() {
  [ "$#" -lt 1 ] && { usage; exit 1; }
  cmd="$1"; shift
  case "$cmd" in
    start)   cmd_start "${1:-agent}" ;;
    stop)    cmd_stop "${1:-agent}" ;;
    status)  cmd_status "${1:-agent}" ;;
    logs)    tail -f "$(log_file "${1:-agent}")" ;;
    list)    ls "$BASE_DIR"/*.conf 2>/dev/null || echo "没有发现配置文件" ;;
    *)       usage ;;
  esac
}

main "$@"
